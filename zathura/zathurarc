include catppuccin-mocha

# ==========================================
# Vim Motions & Keybindings
# ==========================================

map j scroll down
map k scroll up
map h scroll left
map l scroll right

map + zoom in
map - zoom out
map = zoom in
map i zoom in
map o zoom out

map / focus_inputbar "/"
map ? focus_inputbar "?"
map n search forward
map N search backward

map r rotate
map R reload
map f follow
map [p] print

set selection-clipboard clipboard
set scroll-step 50
set zoom-step 10
set render-loading true
set scroll-full-overlap 0.01
set show-wm-left-statusbar true
